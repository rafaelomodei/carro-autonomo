# Fonte de frames:
# image | video | camera | websocket
FRAME_SOURCE_MODE=camera

# Usado quando FRAME_SOURCE_MODE=image|video
FRAME_SOURCE_PATH=../../road_segmentation_lab/fileTest/video_01.mp4

# Usado quando FRAME_SOURCE_MODE=camera
CAMERA_INDEX=0

# Usado quando FRAME_SOURCE_MODE=websocket
# VEHICLE_WS_URL=ws://192.168.15.163:8080
VEHICLE_WS_URL=ws://10.87.37.247:8080

# Backend de inferencia:
# eim | embedded_cpp
#
# O caminho recomendado agora usa o export Linux oficial do Edge Impulse,
# gerado localmente em .eim a partir do zip cpp-linux-v20.
EDGE_IMPULSE_BACKEND=eim

# Caminho do .eim quando EDGE_IMPULSE_BACKEND=eim.
# O start.sh gera esse arquivo automaticamente via build_linux_eim.sh se ele nao existir.
EDGE_IMPULSE_EIM_PATH=../build/edge_impulse_linux_sdk/build/model.eim
EIM_PRINT_INFO_ON_START=true

# Quando true, converte a ROI para grayscale antes de empacotar os pixels em RGB888.
# Quando false, preserva cor para modelos treinados em RGB.
# O pacote cpp-linux-v20 atual ainda reporta 1 canal no metadata, entao o backend eim
# vai forcar grayscale automaticamente mesmo com este valor em false.
TRAFFIC_SIGN_PREPROCESS_GRAYSCALE=false

# Fonte do export Linux/C++ usado tanto pelo fallback embedded_cpp quanto pela geracao do .eim.
EDGE_IMPULSE_MODEL_ZIP=../../edgeImpulse/tcc-pare-direita-esquerda-cam-raspberry-cpp-linux-v20-impulse.zip

# ROI de sinalizacao no frame completo
TRAFFIC_SIGN_ROI_LEFT_RATIO=0.55
TRAFFIC_SIGN_ROI_RIGHT_RATIO=1.00
TRAFFIC_SIGN_ROI_TOP_RATIO=0.08
TRAFFIC_SIGN_ROI_BOTTOM_RATIO=0.72
TRAFFIC_SIGN_DEBUG_ROI_ENABLED=true

# Politica temporal
TRAFFIC_SIGN_MIN_CONFIDENCE=0.50
TRAFFIC_SIGN_MIN_CONSECUTIVE_FRAMES=4
TRAFFIC_SIGN_MAX_MISSED_FRAMES=3
TRAFFIC_SIGN_MAX_RAW_DETECTIONS=3

# Cooldown de emissao do signal:detected
DETECTION_COOLDOWN_MS=2000

# Limite do loop principal
INFERENCE_MAX_FPS=24.0

# Dashboard local
FRAME_PREVIEW_ENABLED=true
