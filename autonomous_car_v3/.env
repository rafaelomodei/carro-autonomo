# Configurações padrão para o Autonomous Car v3
MOTOR_FORWARD_LEFT_PIN=26
MOTOR_BACKWARD_LEFT_PIN=20
MOTOR_FORWARD_RIGHT_PIN=19
MOTOR_BACKWARD_RIGHT_PIN=16
MOTOR_LEFT_INVERTED=false
MOTOR_RIGHT_INVERTED=true
MOTOR_COMMAND_TIMEOUT_MS=150
STEERING_PWM_PIN=13

# Sensibilidade da direção
STEERING_SENSITIVITY=1.0

# Modo de conducao
DRIVING_MODE=manual

# Limites da direção
STEERING_CENTER_ANGLE=90
STEERING_LEFT_LIMIT_DEGREES=80
STEERING_RIGHT_LIMIT_DEGREES=80

# Incremento de comando da direção
STEERING_COMMAND_STEP=0.2

# Configuracao de visao agora fica em config/vision.env
# Configuracao do pipeline de segmentacao agora fica em config/road_segmentation.env
