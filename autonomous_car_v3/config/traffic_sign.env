# Habilita a deteccao de placas via Edge Impulse/FOMO
TRAFFIC_SIGN_ENABLED=true

# ROI retangular de sinalizacao no frame original completo
TRAFFIC_SIGN_ROI_LEFT_RATIO=0.55
TRAFFIC_SIGN_ROI_RIGHT_RATIO=1.00
TRAFFIC_SIGN_ROI_TOP_RATIO=0.08
TRAFFIC_SIGN_ROI_BOTTOM_RATIO=0.72
TRAFFIC_SIGN_DEBUG_ROI_ENABLED=true

# Compatibilidade legada: se LEFT/RIGHT nao forem definidos, o backend ainda aceita
# TRAFFIC_SIGN_ROI_RIGHT_WIDTH_RATIO para derivar uma faixa ancorada a direita.
# TRAFFIC_SIGN_ROI_RIGHT_WIDTH_RATIO=0.45

# Filtro de confianca / estabilidade
TRAFFIC_SIGN_MIN_CONFIDENCE=0.60
TRAFFIC_SIGN_MIN_CONSECUTIVE_FRAMES=2
TRAFFIC_SIGN_MAX_MISSED_FRAMES=3
TRAFFIC_SIGN_MAX_RAW_DETECTIONS=3
