# Regiao de interesse
LANE_ROI_TOP_RATIO=0.5
LANE_ROI_BOTTOM_RATIO=1.0
LANE_REFERENCE_FAR_TOP_RATIO=0.00
LANE_REFERENCE_FAR_BOTTOM_RATIO=0.33
LANE_REFERENCE_MID_TOP_RATIO=0.33
LANE_REFERENCE_MID_BOTTOM_RATIO=0.66
LANE_REFERENCE_NEAR_TOP_RATIO=0.66
LANE_REFERENCE_NEAR_BOTTOM_RATIO=1.00
LANE_ROI_POLYGON_TOP_WIDTH_RATIO=1.0
LANE_ROI_POLYGON_BOTTOM_WIDTH_RATIO=1.0
LANE_ROI_POLYGON_CENTER_X_RATIO=0.5
LANE_HOOD_MASK_ENABLED=true
LANE_HOOD_MASK_WIDTH_RATIO=0.34
LANE_HOOD_MASK_HEIGHT_RATIO=0.22
LANE_HOOD_MASK_CENTER_X_RATIO=0.5
LANE_HOOD_MASK_BOTTOM_OFFSET_RATIO=0.02

# Suavizacao
