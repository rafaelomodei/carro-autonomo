# Configurações de hardware
MOTOR_FORWARD_LEFT_PIN=26
MOTOR_BACKWARD_LEFT_PIN=20
MOTOR_FORWARD_RIGHT_PIN=19
MOTOR_BACKWARD_RIGHT_PIN=16
MOTOR_LEFT_INVERTED=false
MOTOR_RIGHT_INVERTED=true
# Tempo máximo (ms) sem novos comandos de movimento antes de parar automaticamente
MOTOR_COMMAND_TIMEOUT_MS=150
STEERING_PWM_PIN=13

# Sensibilidade de controle
STEERING_SENSITIVITY=1.0

# Modo de condução (manual/autonomous)
DRIVING_MODE=manual

# Limites de direção
STEERING_CENTER_ANGLE=90
STEERING_LEFT_LIMIT_DEGREES=80
STEERING_RIGHT_LIMIT_DEGREES=80

# PID da direção (obsoleto – mantido apenas como referência para futuras integrações)
# STEERING_PID_KP=20.0
# STEERING_PID_KI=0.15
# STEERING_PID_KD=0.10
# STEERING_PID_OUTPUT_LIMIT=0.10
# STEERING_PID_INTERVAL_MS=30

# Incremento de comando de direção
STEERING_COMMAND_STEP=0.2

# Controle autonomo de direção
AUTONOMOUS_PID_KP=0.45
AUTONOMOUS_PID_KI=0.02
AUTONOMOUS_PID_KD=0.08
AUTONOMOUS_PID_OUTPUT_LIMIT=0.55
AUTONOMOUS_PREVIEW_NEAR_WEIGHT=0.5
AUTONOMOUS_PREVIEW_MID_WEIGHT=0.3
AUTONOMOUS_PREVIEW_FAR_WEIGHT=0.2
AUTONOMOUS_MAX_STEERING_DELTA_PER_UPDATE=0.08
AUTONOMOUS_MIN_CONFIDENCE=0.25
AUTONOMOUS_LANE_LOSS_TIMEOUT_MS=250

# Configuracao de visao agora fica em config/vision.env
# Configuracao do pipeline de segmentacao agora fica em config/road_segmentation.env
